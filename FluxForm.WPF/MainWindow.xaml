<ui:FluentWindow x:Class="FluxForm.WPF.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:FluxForm.WPF.ViewModels"
                 Title="FluxForm"
                 Width="1360"
                 Height="860"
                 MinWidth="1160"
                 MinHeight="760"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d"
                 AllowDrop="True"
                 PreviewDragEnter="Window_PreviewDragEnter"
                 PreviewDragLeave="Window_PreviewDragLeave"
                 PreviewDragOver="Window_PreviewDragOver"
                 PreviewDrop="Window_PreviewDrop">

    <ui:FluentWindow.Resources>
        <vm:MainViewModel x:Key="ViewModel" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="FluxForm" />

        <Border Grid.Row="1"
                Margin="12,12,12,0"
                Padding="16,12"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center" ItemHeight="36" ItemWidth="Auto">
                    <ui:Button Margin="0,0,8,8" Command="{Binding AddFilesCommand}" Icon="{ui:SymbolIcon FolderOpen24}">添加文件</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding AddFolderCommand}" Icon="{ui:SymbolIcon FolderArrowRight24}">添加文件夹</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding SetOutputDirectoryCommand}" Icon="{ui:SymbolIcon Folder24}">输出目录</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding StartCommand}" Icon="{ui:SymbolIcon Play24}">开始</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding CancelCommand}" Icon="{ui:SymbolIcon Dismiss24}">停止</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding ClearCommand}" Icon="{ui:SymbolIcon Delete24}">清空</ui:Button>
                    <ui:Button Margin="0,0,8,8" Command="{Binding RetryFailedTasksCommand}" Icon="{ui:SymbolIcon ArrowClockwise24}">重新加入失败任务</ui:Button>
                </WrapPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Right" FontSize="12" Opacity="0.72" Text="全局进度" />
                    <ProgressBar Width="220" Height="8" Margin="0,6,0,0" Maximum="100" Value="{Binding TotalProgress, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="18"
                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="待配置区" />
                        <TextBlock Margin="0,6,0,0" Opacity="0.72" Text="先添加同类型文件，再选择输出格式和最小参数后加入队列。" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="12" Opacity="0.72" Text="当前类型" />
                                <TextBlock Margin="0,4,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding PendingCategoryText}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="10,6"
                                    Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding PendingFileSummary}" />
                            </Border>
                        </Grid>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="待处理文件" />
                            <Border Margin="0,8,0,0"
                                    MinHeight="180"
                                    Padding="0"
                                    Background="{ui:ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding PendingBatch.Files}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="10,10,10,0"
                                                        Padding="12"
                                                        Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="{Binding Summary}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsPendingBatchEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ui:SymbolIcon FontSize="42" Symbol="ArrowUpload24" />
                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="拖拽或点击上方按钮添加文件" />
                                        <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="同一批次仅支持单一类型文件。" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="输出格式" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          Height="36"
                                          IsEditable="False"
                                          ItemsSource="{Binding FormatPresets}"
                                          SelectedValue="{Binding PendingBatch.OutputFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Extension">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Opacity="0.72"
                                           Text="也可点击下方格式快捷入口" />
                            </Grid>
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding CommonFormatPresets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Button Margin="0,0,8,8"
                                                   Padding="12,4"
                                                   Command="{Binding DataContext.ApplyFormatCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding Extension}">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </ui:Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="基础参数" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="按需设置帧率和画面比例；留空则使用默认参数。" />
                            <UniformGrid Margin="0,10,0,0" Columns="2" Rows="2">
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Margin="0,0,0,4" Text="frameRate" />
                                    <TextBox Height="36" Text="{Binding PendingFrameRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 24 / 30 / 60" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Margin="0,0,0,4" Text="aspectRatio" />
                                    <TextBox Height="36" Text="{Binding PendingAspectRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 16:9 / 4:3" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Margin="0,0,0,4" Text="当前批次输出目录" />
                                    <TextBox Height="36" IsReadOnly="True" Text="{Binding OutputDirectory}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Margin="0,0,0,4" Text="参数摘要" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding PendingOptionSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>

                        <Border Margin="0,18,0,0"
                                Padding="12"
                                Background="#19D13438"
                                BorderBrush="#66D13438"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding HasPendingValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Foreground="#9F1239" Text="{Binding PendingBatch.ValidationMessage}" TextWrapping="Wrap" />
                        </Border>

                        <ui:Button Margin="0,18,0,0"
                                   Height="36"
                                   Command="{Binding ClearPendingBatchCommand}"
                                   Icon="{ui:SymbolIcon Delete24}">
                            清除待配置
                        </ui:Button>

                        <ui:Button Margin="0,8,0,0"
                                   Height="40"
                                   Command="{Binding EnqueuePendingBatchCommand}"
                                   Icon="{ui:SymbolIcon Add24}">
                            加入队列
                        </ui:Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="160" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="批次队列" />
                        <TextBlock Margin="0,6,0,0" Opacity="0.72" Text="同批次任务会聚合在一个卡片中，展开可查看每个任务的小卡片状态。" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Batches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:BatchItemViewModel}">
                                        <Border Margin="0,0,0,12"
                                                Padding="16"
                                                Background="{ui:ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding BatchId}" />
                                                        <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="{Binding ConfigSummary}" TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="{Binding TotalCount, StringFormat=任务数：{0}}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SucceededCount, StringFormat=完成 {0}}" />
                                                        <TextBlock HorizontalAlignment="Right" Text="{Binding FailedCount, StringFormat=失败 {0}}" />
                                                        <TextBlock HorizontalAlignment="Right" Text="{Binding CancelledCount, StringFormat=取消 {0}}" />
                                                        <TextBlock HorizontalAlignment="Right" Text="{Binding PendingCount, StringFormat=待处理 {0}}" />
                                                    </StackPanel>
                                                </Grid>

                                                <ProgressBar Margin="0,12,0,0" Height="8" Maximum="100" Value="{Binding TotalProgress, Mode=OneWay}" />

                                                <Expander Margin="0,14,0,0" IsExpanded="{Binding IsExpanded}">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="SemiBold" Text="展开查看任务小卡片状态" />
                                                    </Expander.Header>
                                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Tasks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                                                <Border Width="220"
                                                                        Margin="0,0,12,12"
                                                                        Padding="12"
                                                                        Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                                                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10">
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Margin="0,6,0,0" Opacity="0.72" Text="{Binding OutputFormat, StringFormat=目标：{0}}" />
                                                                        <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="{Binding ParameterSummary}" TextWrapping="Wrap" />
                                                                        <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding StatusText}" />
                                                                        <ProgressBar Margin="0,8,0,0" Height="6" Maximum="100" Value="{Binding Progress, Mode=OneWay}" />
                                                                        <TextBlock Margin="0,8,0,0" FontSize="12" Opacity="0.72" Text="{Binding Message}" TextWrapping="Wrap" />
                                                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                                            <ui:Button Margin="0,0,8,0"
                                                                                       Padding="8,2"
                                                                                       Command="{Binding DataContext.OpenOutputCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       CommandParameter="{Binding OutputPath}"
                                                                                       Icon="{ui:SymbolIcon FolderOpen24}">
                                                                                打开位置
                                                                            </ui:Button>
                                                                            <ui:Button Padding="8,2"
                                                                                       Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                       CommandParameter="{Binding}"
                                                                                       Icon="{ui:SymbolIcon Delete24}">
                                                                                移除
                                                                            </ui:Button>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ui:SymbolIcon FontSize="46" Symbol="Collections24" />
                            <TextBlock Margin="0,12,0,0" FontSize="16" FontWeight="SemiBold" Text="批次队列为空" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.72" Text="先在左侧待配置区加入文件并创建批次。" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="12"
                            Background="{ui:ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="运行日志" />
                            <ScrollViewer Grid.Row="1" Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                                <TextBlock FontFamily="Consolas" Text="{Binding LogText}" TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DropOverlay"
                Grid.Row="2"
                Margin="12"
                IsHitTestVisible="False"
                Panel.ZIndex="100"
                Background="#B2000000"
                CornerRadius="12"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:SymbolIcon Margin="0,0,0,12" FontSize="48" Foreground="White" Symbol="ArrowDownload24" />
                <TextBlock FontSize="20" Foreground="White" Text="释放文件以加入待配置区" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Margin="12,8" Text="{Binding StatusText}" />
        </Border>
    </Grid>
</ui:FluentWindow>
