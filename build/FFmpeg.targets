<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Publish can optionally bundle ffmpeg into tools/ffmpeg/.

    Normal publish stays fast and does not download from the network. If
    tools-cache/ffmpeg-release-essentials.zip exists, ffmpeg is bundled from
    that cache. To allow a network download, pass:

      -p:BundleFFmpeg=true -p:DownloadFFmpegDuringPublish=true
  -->
  <PropertyGroup>
    <FFmpegUrl>https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-essentials.zip</FFmpegUrl>
    <FFmpegPublishRoot>$(PublishDir.TrimEnd('\'))</FFmpegPublishRoot>
    <FFmpegPublishDir>$([System.IO.Path]::Combine($(FFmpegPublishRoot), 'tools', 'ffmpeg'))</FFmpegPublishDir>
    <FFmpegArchiveName>ffmpeg-release-essentials.zip</FFmpegArchiveName>
    <FFmpegArchivePath>$([System.IO.Path]::Combine($(FFmpegPublishDir), $(FFmpegArchiveName)))</FFmpegArchivePath>
    <FFmpegCachePath>$([System.IO.Path]::Combine($(MSBuildThisFileDirectory), '..', 'tools-cache', $(FFmpegArchiveName)))</FFmpegCachePath>
    <BundleFFmpeg Condition="'$(BundleFFmpeg)' == '' and Exists('$(FFmpegCachePath)')">true</BundleFFmpeg>
    <BundleFFmpeg Condition="'$(BundleFFmpeg)' == ''">false</BundleFFmpeg>
    <DownloadFFmpegDuringPublish Condition="'$(DownloadFFmpegDuringPublish)' == ''">false</DownloadFFmpegDuringPublish>
    <FFmpegDownloadSwitch Condition="'$(DownloadFFmpegDuringPublish)' == 'true'">-AllowDownload</FFmpegDownloadSwitch>
  </PropertyGroup>

  <Target Name="CleanStaleFFmpegArchiveForPublish"
          AfterTargets="Publish"
          BeforeTargets="BundleFFmpegForPublish"
          Condition="Exists('$(FFmpegArchivePath)')">
    <Message Text="[FluxForm] 删除发布目录中的残留 ffmpeg 压缩包：$(FFmpegArchivePath)" Importance="high" />
    <Delete Files="$(FFmpegArchivePath)" />
  </Target>

  <Target Name="BundleFFmpegForPublish"
          AfterTargets="Publish"
          Condition="'$(BundleFFmpeg)' == 'true'">
    <Message Text="[FluxForm] 准备内置 ffmpeg：$(FFmpegPublishDir)" Importance="high" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)BundleFfmpegForPublish.ps1&quot; -PublishDir &quot;$(FFmpegPublishRoot)&quot; -CachePath &quot;$(FFmpegCachePath)&quot; -DownloadUrl &quot;$(FFmpegUrl)&quot; $(FFmpegDownloadSwitch)" />
  </Target>
</Project>
